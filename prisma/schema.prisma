// ATP Scales - Prisma Schema
// Architected to support: Meta Ads, Google Ads, Stripe, Calendly integrations
// without schema rebuilds. External data is stored in AdPlatformData / IntegrationSync tables.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  TEAM_MEMBER
  CLIENT
}

enum ClientStatus {
  ACTIVE
  PAUSED
  CHURNED
  ONBOARDING
  PROSPECT
}

enum PerformanceStatus {
  IMPROVING
  STABLE
  NEEDS_ATTENTION
  CRITICAL
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  COMPLETED
  DRAFT
}

enum Platform {
  META
  GOOGLE
  TIKTOK
  LINKEDIN
  YOUTUBE
  OTHER
}

enum IntegrationProvider {
  META_ADS
  GOOGLE_ADS
  STRIPE
  CALENDLY
  MANUAL
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  PENDING
}

enum CreativeType {
  IMAGE
  VIDEO
  CAROUSEL
}

enum CreativeStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum FileType {
  PDF
  IMAGE
  VIDEO
  SPREADSHEET
  DOCUMENT
  OTHER
}

enum UpdateCategory {
  WEEKLY_RECAP
  STRATEGY_CHANGE
  CREATIVE_UPDATE
  PERFORMANCE_ALERT
  GENERAL
}

// ─────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  password      String?   // hashed via bcrypt
  role          Role      @default(CLIENT)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  clientProfile    ClientProfile?   @relation("ClientUser")
  managedClients   ClientProfile[]  @relation("AccountManager")
  sessions         Session[]
  accounts         Account[]
  authoredUpdates  ClientUpdate[]   @relation("UpdateAuthor")
  uploadedFiles    ClientFile[]     @relation("FileUploader")
  auditLogs        AuditLog[]

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// CLIENT PROFILES
// ─────────────────────────────────────────────

model ClientProfile {
  id               String        @id @default(cuid())
  userId           String        @unique
  companyName      String
  industry         String?
  website          String?
  logoUrl          String?
  phone            String?
  address          String?
  status           ClientStatus  @default(ONBOARDING)
  performanceStatus PerformanceStatus @default(STABLE)
  monthlyBudget    Decimal?      @db.Decimal(12, 2)
  planId           String?
  accountManagerId String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  
  // Relations
  user             User          @relation("ClientUser", fields: [userId], references: [id], onDelete: Cascade)
  accountManager   User?         @relation("AccountManager", fields: [accountManagerId], references: [id])
  plan             Plan?         @relation(fields: [planId], references: [id])
  onboarding       Onboarding?
  campaigns        Campaign[]
  metrics          MetricSnapshot[]
  updates          ClientUpdate[]
  files            ClientFile[]
  integrations     ClientIntegration[]
  adPlatformData   AdPlatformData[]
  metaBreakdowns   MetaBreakdownRow[]
  stripeData       StripeData[]
  calendlyData     CalendlyData[]

  @@index([status])
  @@index([accountManagerId])
}

// ─────────────────────────────────────────────
// ONBOARDING
// ─────────────────────────────────────────────

model Onboarding {
  id                  String   @id @default(cuid())
  clientProfileId     String   @unique
  // Offer details
  offerName           String?
  offerDescription    String?  @db.Text
  offerPrice          String?
  offerUSP            String?  @db.Text
  // Target audience
  targetAudience      String?  @db.Text
  targetAgeRange      String?
  targetLocations     String[] // array of locations
  targetInterests     String[] // array of interests
  targetDemographics  String?  @db.Text
  // Access status
  metaAccessGranted   Boolean  @default(false)
  googleAccessGranted Boolean  @default(false)
  websiteAccessGranted Boolean @default(false)
  crmAccessGranted    Boolean  @default(false)
  accessNotes         String?  @db.Text
  // Creative assets
  brandGuidelinesUrl  String?
  creativeAssetsUrl   String?
  // Call notes
  callNotes           String?  @db.Text
  callDate            DateTime?
  callRecordingUrl    String?
  // Completion
  isComplete          Boolean  @default(false)
  completedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  clientProfile       ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// PLANS / PACKAGES
// ─────────────────────────────────────────────

model Plan {
  id            String    @id @default(cuid())
  name          String    @unique // e.g. "Starter", "Growth", "Scale"
  description   String?
  priceMonthly  Decimal?  @db.Decimal(10, 2)
  features      Json      // array of feature strings
  maxCampaigns  Int?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  clients       ClientProfile[]
}

// ─────────────────────────────────────────────
// METRICS (manual entry + integration snapshots)
// ─────────────────────────────────────────────

model MetricSnapshot {
  id                  String   @id @default(cuid())
  clientProfileId     String
  // Time
  date                DateTime @db.Date
  periodStart         DateTime @db.Date
  periodEnd           DateTime @db.Date
  // Core KPIs
  adSpend             Decimal  @db.Decimal(12, 2) @default(0)
  revenue             Decimal  @db.Decimal(12, 2) @default(0)
  roas                Decimal  @db.Decimal(8, 4)  @default(0)
  leads               Int      @default(0)
  costPerLead         Decimal  @db.Decimal(10, 2) @default(0)
  appointments        Int      @default(0)
  costPerAppointment  Decimal  @db.Decimal(10, 2) @default(0)
  conversionRate      Decimal  @db.Decimal(6, 4)  @default(0)
  // Funnel
  impressions         Int      @default(0)
  clicks              Int      @default(0)
  ctr                 Decimal  @db.Decimal(6, 4)  @default(0)
  cpc                 Decimal  @db.Decimal(10, 2) @default(0)
  purchases           Int      @default(0)
  // Source tracking
  source              IntegrationProvider @default(MANUAL)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  clientProfile       ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@unique([clientProfileId, date])
  @@index([clientProfileId, date])
}

// ─────────────────────────────────────────────
// CAMPAIGNS
// ─────────────────────────────────────────────

model Campaign {
  id              String         @id @default(cuid())
  clientProfileId String
  name            String
  platform        Platform
  status          CampaignStatus @default(ACTIVE)
  // External IDs for integration syncing
  externalId      String?        // Meta campaign_id, Google campaign_id, etc.
  objective       String?
  startDate       DateTime?      @db.Date
  endDate         DateTime?      @db.Date
  dailyBudget     Decimal?       @db.Decimal(10, 2)
  totalBudget     Decimal?       @db.Decimal(12, 2)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  clientProfile   ClientProfile  @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  stats           CampaignStat[]
  creatives       Creative[]

  @@index([clientProfileId, status])
  @@index([externalId, platform])
}

model CampaignStat {
  id           String   @id @default(cuid())
  campaignId   String
  date         DateTime @db.Date
  spend        Decimal  @db.Decimal(10, 2) @default(0)
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  ctr          Decimal  @db.Decimal(6, 4)  @default(0)
  cpc          Decimal  @db.Decimal(10, 2) @default(0)
  leads        Int      @default(0)
  cpl          Decimal  @db.Decimal(10, 2) @default(0)
  purchases    Int      @default(0)
  revenue      Decimal  @db.Decimal(12, 2) @default(0)
  roas         Decimal  @db.Decimal(8, 4)  @default(0)
  source       IntegrationProvider @default(MANUAL)
  createdAt    DateTime @default(now())

  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([campaignId, date])
}

// ─────────────────────────────────────────────
// CREATIVES / ADS
// ─────────────────────────────────────────────

model Creative {
  id           String         @id @default(cuid())
  campaignId   String
  name         String
  headline     String?
  description  String?        @db.Text
  imageUrl     String?
  type         CreativeType   @default(IMAGE)
  status       CreativeStatus @default(ACTIVE)
  // Performance metrics (aggregated from ad platform)
  impressions  Int            @default(0)
  clicks       Int            @default(0)
  spend        Decimal        @db.Decimal(10, 2) @default(0)
  leads        Int            @default(0)
  ctr          Decimal        @db.Decimal(6, 4)  @default(0)
  cpc          Decimal        @db.Decimal(10, 2) @default(0)
  cpl          Decimal        @db.Decimal(10, 2) @default(0)
  externalId   String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  campaign     Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, name])
  @@index([campaignId])
}

// ─────────────────────────────────────────────
// CLIENT UPDATES / NOTES
// ─────────────────────────────────────────────

model ClientUpdate {
  id              String         @id @default(cuid())
  clientProfileId String
  authorId        String
  title           String
  content         String         @db.Text
  category        UpdateCategory @default(WEEKLY_RECAP)
  isRead          Boolean        @default(false)
  isPinned        Boolean        @default(false)
  publishedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  clientProfile   ClientProfile  @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  author          User           @relation("UpdateAuthor", fields: [authorId], references: [id])

  @@index([clientProfileId, createdAt])
}

// ─────────────────────────────────────────────
// FILES / REPORTS
// ─────────────────────────────────────────────

model ClientFile {
  id              String   @id @default(cuid())
  clientProfileId String
  uploadedById    String
  name            String
  description     String?
  fileType        FileType @default(OTHER)
  mimeType        String?
  size            Int?     // bytes
  url             String   // S3/R2/Vercel Blob URL
  isPublic        Boolean  @default(false)
  createdAt       DateTime @default(now())

  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  uploadedBy      User          @relation("FileUploader", fields: [uploadedById], references: [id])

  @@index([clientProfileId])
}

// ─────────────────────────────────────────────
// INTEGRATIONS (connection credentials & status)
// These store OAuth tokens and connection status per client per provider
// ─────────────────────────────────────────────

model ClientIntegration {
  id              String              @id @default(cuid())
  clientProfileId String
  provider        IntegrationProvider
  status          IntegrationStatus   @default(PENDING)
  // OAuth tokens (encrypted at rest in production)
  accessToken     String?             @db.Text
  refreshToken    String?             @db.Text
  tokenExpiresAt  DateTime?
  // Provider-specific IDs
  externalAccountId String?           // Meta Ad Account ID, Google Customer ID, Stripe Customer ID, etc.
  externalData    Json?               // Flexible blob for provider-specific config
  lastSyncedAt    DateTime?
  syncError       String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  clientProfile   ClientProfile       @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@unique([clientProfileId, provider])
  @@index([provider, status])
}

// ─────────────────────────────────────────────
// INTEGRATION-SPECIFIC DATA TABLES
// These hold raw/normalized data pulled from external APIs
// Designed so MetricSnapshot + CampaignStat remain the source of truth for the UI,
// while these tables hold the raw sync'd data before normalization.
// ─────────────────────────────────────────────

// Meta Ads & Google Ads share this table (distinguished by platform field)
model AdPlatformData {
  id              String   @id @default(cuid())
  clientProfileId String
  platform        Platform
  // Raw payload from API (Meta Insights / Google Reports)
  rawPayload      Json
  // Normalized key fields
  campaignId      String?
  adSetId         String?
  adId            String?
  date            DateTime @db.Date
  spend           Decimal  @db.Decimal(10, 2) @default(0)
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  leads           Int      @default(0)
  purchases       Int      @default(0)
  revenue         Decimal  @db.Decimal(12, 2) @default(0)
  syncedAt        DateTime @default(now())

  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@index([clientProfileId, platform, date])
}

// Stripe: payment / revenue data
model StripeData {
  id              String   @id @default(cuid())
  clientProfileId String
  stripeCustomerId String?
  // Raw Stripe event or object
  rawPayload      Json
  // Normalized
  eventType       String   // e.g. "payment_intent.succeeded", "invoice.paid"
  amount          Decimal  @db.Decimal(12, 2) @default(0)
  currency        String   @default("usd")
  status          String?
  eventDate       DateTime
  syncedAt        DateTime @default(now())

  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@index([clientProfileId, eventType, eventDate])
}

// Calendly: appointment / booking data
model CalendlyData {
  id              String   @id @default(cuid())
  clientProfileId String
  // Raw Calendly webhook payload
  rawPayload      Json
  // Normalized
  eventType       String   // e.g. "invitee.created", "invitee.canceled"
  eventName       String?
  inviteeName     String?
  inviteeEmail    String?
  scheduledAt     DateTime?
  status          String?   // "active", "canceled"
  utmSource       String?   // for attribution tracking
  utmCampaign     String?
  syncedAt        DateTime  @default(now())

  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@index([clientProfileId, scheduledAt])
}

// ─────────────────────────────────────────────
// META BREAKDOWN DATA
// Stores normalized Meta API breakdown rows (age, gender, country, hourly, asset, action).
// Populated by syncClientMetaData() when live API credentials are connected.
// The dashboard currently reads from this table via breakdown.service.ts;
// if empty, it falls back to mock data automatically.
// ─────────────────────────────────────────────

model MetaBreakdownRow {
  id              String   @id @default(cuid())
  clientProfileId String
  // Date range this row covers
  date            DateTime @db.Date
  // Which breakdown dimension: "age" | "gender" | "country" | "hourly" | "title_asset" | "body_asset" | "cta_asset" | "action_type"
  breakdown       String
  // The dimension value: e.g. "25-34", "female", "US", "9", "Learn More", "lead"
  dimension       String
  // Core metrics
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  spend           Decimal  @db.Decimal(10, 2) @default(0)
  leads           Int      @default(0)
  revenue         Decimal  @db.Decimal(12, 2) @default(0)
  // Modeled conversion flag (is_conversion_id_modeled)
  isModeled       Boolean  @default(false)
  // Source tracking
  source          IntegrationProvider @default(META_ADS)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@unique([clientProfileId, date, breakdown, dimension])
  @@index([clientProfileId, breakdown, date])
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String   // e.g. "client.create", "metric.update", "file.upload"
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([entityType, entityId])
}
