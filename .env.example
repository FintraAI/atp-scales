# ATP Scales — Environment Variables
# Copy this to .env.local and fill in all values

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Local:  postgresql://postgres:password@localhost:5432/atp_scales
# Neon:   postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/atp_scales?sslmode=require
# Supabase: postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:password@localhost:5432/atp_scales"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-here-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# ── Meta / Facebook Ads API ───────────────────────────────────────────────────
# Create at: https://developers.facebook.com/apps
# Permissions needed: ads_read, ads_management, business_management, leads_retrieval
META_APP_ID="your_meta_app_id"
META_APP_SECRET="your_meta_app_secret"

# ── Google Ads API (future) ───────────────────────────────────────────────────
# GOOGLE_ADS_CLIENT_ID="your_google_client_id"
# GOOGLE_ADS_CLIENT_SECRET="your_google_client_secret"
# GOOGLE_ADS_DEVELOPER_TOKEN="your_developer_token"

# ── Stripe (future) ───────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Calendly (future) ─────────────────────────────────────────────────────────
# CALENDLY_CLIENT_ID="your_calendly_client_id"
# CALENDLY_CLIENT_SECRET="your_calendly_client_secret"
# CALENDLY_WEBHOOK_SECRET="your_webhook_secret"

# ── File Storage ──────────────────────────────────────────────────────────────
# Vercel Blob (recommended for Vercel deployments)
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ── Cron Security ─────────────────────────────────────────────────────────────
# Used to authenticate scheduled sync jobs (Vercel cron / external cron)
# Generate: openssl rand -base64 24
CRON_SECRET_KEY="your-cron-secret-key"
